{"data":{"event":{"_sys":{"filename":"20250402_Megagame_Alliance","basename":"20250402_Megagame_Alliance.mdx","hasReferences":false,"breadcrumbs":["20250402_Megagame_Alliance"],"path":"content/event/20250402_Megagame_Alliance.mdx","relativePath":"20250402_Megagame_Alliance.mdx","extension":".mdx"},"id":"content/event/20250402_Megagame_Alliance.mdx","__typename":"Event","title":"Megagame: Alliance","date":"2025-04-01T22:00:00.000Z","body":{"type":"root","children":[{"type":"h2","children":[{"type":"text","text":"Megagame: Alliance"}]},{"type":"h3","children":[{"type":"text","text":"When?"}]},{"type":"p","children":[{"type":"text","text":"This game will be played from 19:00 to 22:00 on Wednesday, the 2nd of April 2025."}]},{"type":"h3","children":[{"type":"text","text":"Where?"}]},{"type":"p","children":[{"type":"text","text":"We gather in Crafty Potions. Found at Sint-Jansstraat 21, 8500 Kortrijk"}]},{"type":"h3","children":[{"type":"text","text":"What?"}]},{"type":"p","children":[{"type":"text","text":"Megagame: Alliance features a recognisable version of our world some time in the future. You are part of the council in charge of your nation. Growth is the main goal of this game and you as the advisors want to spread your influence through the natural resources your country has access to. Will you open the world to an era of peace or are more aggressive tactics necessary to come out on top?"}]},{"type":"p","children":[{"type":"text","text":"Similar to other Roleplaying games, turns are taken where you communicate with your allies, but also with other nations. At the end a turn, you fill out an action report. You'll suggest an action taken by your nation based on the information gathered throughout the turn. These action reports are given to the game masters who'll discuss the likeliness of your actions taking place. Resources can be used to empower the success of these action. The game masters will try and create an interesting story with twists and turns while also giving thought to the various strategies and alliances forged throughout the game"}]},{"type":"p","children":[{"type":"text","text":"Let's make this an event to remember."}]},{"type":"h3","children":[{"type":"text","text":"Sign up:"}]},{"type":"p","children":[{"type":"text","text":"Sign up here: TBA"}]},{"type":"p","children":[{"type":"text","text":"It is possible to show up at the event without signing up."}]}]},"signupUrl":null,"groups":null}},"errors":null,"query":"\n    query event($relativePath: String!) {\n  event(relativePath: $relativePath) {\n    ... on Document {\n      _sys {\n        filename\n        basename\n        hasReferences\n        breadcrumbs\n        path\n        relativePath\n        extension\n      }\n      id\n    }\n    ...EventParts\n  }\n}\n    \n    fragment EventParts on Event {\n  __typename\n  title\n  date\n  body\n  signupUrl\n  groups {\n    __typename\n    name\n    maxSlots\n  }\n}\n    "}