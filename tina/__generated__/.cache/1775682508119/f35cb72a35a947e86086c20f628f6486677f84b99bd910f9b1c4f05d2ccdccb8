{"data":{"pageConnection":{"pageInfo":{"hasPreviousPage":false,"hasNextPage":false,"startCursor":"Y29udGVudC9wYWdlL1RoZV9Wb2lkLm1keA==","endCursor":"Y29udGVudC9wYWdlL1RoZV9Wb2lkLm1keA=="},"totalCount":1,"edges":[{"cursor":"Y29udGVudC9wYWdlL1RoZV9Wb2lkLm1keA==","node":{"_sys":{"filename":"The_Void","basename":"The_Void.mdx","hasReferences":null,"breadcrumbs":["The_Void"],"path":"content/page/The_Void.mdx","relativePath":"The_Void.mdx","extension":".mdx"},"id":"content/page/The_Void.mdx","__typename":"Page","title":"The Void","body":{"type":"root","children":[{"type":"h1","children":[{"type":"text","text":"The Void: A Living World Campaign"}]},{"type":"p","children":[{"type":"text","text":"Want to play TTRPGs but can't commit to a fixed weekly group? "},{"type":"text","text":"The Void","bold":true},{"type":"text","text":" is our persistent, \"West Marches\" style campaign where you choose when to play."}]},{"type":"p","children":[{"type":"text","text":"Whether you're a fan of "},{"type":"text","text":"Dungeons & Dragons 5e","bold":true},{"type":"text","text":" or looking to try the deep customization of "},{"type":"text","text":"Pathfinder 2e","bold":true},{"type":"text","text":", you'll find a seat at our table. Our world is home to both systems, giving you the freedom to explore the same lore through different rules."}]},{"type":"h2","children":[{"type":"text","text":"🚀 Quick Start"}]},{"type":"ol","children":[{"type":"li","children":[{"type":"lic","children":[{"type":"text","text":"Join the Tavern","bold":true},{"type":"text","text":": Hop into the "},{"type":"a","url":"https://discord.com/channels/878674783972261918/1322273585032724510","title":null,"children":[{"type":"text","text":"#ouroboros_inn","bold":true}]},{"type":"text","text":" on Discord to meet the community."}]}]},{"type":"li","children":[{"type":"lic","children":[{"type":"text","text":"Find a Session","bold":true},{"type":"text","text":": Browse upcoming games for both D&D and Pathfinder on the "},{"type":"a","url":"https://guild.tarragon.be","title":null,"children":[{"type":"text","text":"Guild Planning Tool","bold":true}]},{"type":"text","text":"."}]}]},{"type":"li","children":[{"type":"lic","children":[{"type":"text","text":"Read the Lore","bold":true},{"type":"text","text":": Check the "},{"type":"a","url":"https://void.tarragon.be","title":null,"children":[{"type":"text","text":"Void Wiki","bold":true}]},{"type":"text","text":" to learn about the world and character creation."}]}]}]},{"type":"hr","children":[{"type":"text","text":""}]},{"type":"h2","children":[{"type":"text","text":"What is "},{"type":"text","text":"The Void","italic":true},{"type":"text","text":"?"}]},{"type":"p","children":[{"type":"text","text":"\"The Void\" is a shared universe that supports both "},{"type":"text","text":"D&D 5e","bold":true},{"type":"text","text":" and "},{"type":"text","text":"Pathfinder 2e","bold":true},{"type":"text","text":"."}]},{"type":"p","children":[{"type":"text","text":"Unlike a traditional campaign with the same 4 players every week, The Void has dozens of players and multiple GMs (Voidmasters). You create a character, and whenever a Voidmaster posts a session that fits your schedule, you sign up!"}]},{"type":"p","children":[{"type":"text","text":"Your character earns XP, gold, and reputation that carries over to every future session you play in that system."}]},{"type":"h2","children":[{"type":"text","text":"New to TTRPGs?"}]},{"type":"p","children":[{"type":"text","text":"You are absolutely welcome! Most of our players started with D&D, but many have discovered a love for Pathfinder 2e's tactical depth. Our community is incredibly helpful—just mention you're new in Discord, and we'll help you build your first hero, regardless of which system you choose."}]},{"type":"h2","children":[{"type":"text","text":"How it Works"}]},{"type":"ul","children":[{"type":"li","children":[{"type":"lic","children":[{"type":"text","text":"Communication","bold":true},{"type":"text","text":": Everything happens on our "},{"type":"a","url":"https://discord.com/invite/TjDUu2Gkag","title":null,"children":[{"type":"text","text":"Discord"}]},{"type":"text","text":". Assign yourself the \"Void\" role to see the channels."}]}]},{"type":"li","children":[{"type":"lic","children":[{"type":"text","text":"Cost","bold":true},{"type":"text","text":": Sessions are "},{"type":"text","text":"completely free","bold":true},{"type":"text","text":" to attend."}]}]},{"type":"li","children":[{"type":"lic","children":[{"type":"text","text":"Support your Voidmaster","bold":true},{"type":"text","text":": While sessions are free, we highly encourage \"tipping\" your Voidmaster! A compliment, a cold drink, or a small donation is a great way to show your appreciation for the adventure they've prepared."}]}]},{"type":"li","children":[{"type":"lic","children":[{"type":"text","text":"In-Person","bold":true},{"type":"text","text":": Most sessions take place at our venue in Kortrijk."}]}]}]},{"type":"hr","children":[{"type":"text","text":""}]},{"type":"h2","children":[{"type":"text","text":"Become a Voidmaster"}]},{"type":"p","children":[{"type":"text","text":"Love to GM? We’re always looking for new Voidmasters! You have the freedom to run stories in the system you're most comfortable with."}]},{"type":"ul","children":[{"type":"li","children":[{"type":"lic","children":[{"type":"text","text":"Progression","bold":true},{"type":"text","text":": You earn XP and rewards for your own player characters for every session you host."}]}]},{"type":"li","children":[{"type":"lic","children":[{"type":"text","text":"Collaboration","bold":true},{"type":"text","text":": Join our GM-only channels to help shape the world's evolving story."}]}]},{"type":"li","children":[{"type":"lic","children":[{"type":"text","text":"Support","bold":true},{"type":"text","text":": We provide the framework, the wiki, and the planning tools; you provide the adventure."}]}]}]},{"type":"p","children":[{"type":"text","text":"Interested? Chat with us in the Discord or send a PM to one of the organizers!"}]}]},"enabled":true,"snippet":{"type":"root","children":[{"type":"p","children":[{"type":"text","text":"Play D&D and Pathfinder on your own schedule.","bold":true},{"type":"text","text":"\nJoin our \"Living World\" campaign. No weekly commitment needed—just jump into a session when you're free and build your legend!"}]}]},"icon":"https://assets.tina.io/631e945a-de93-4cb5-9391-801af2372e16/Void_Logo.svg"}}]}},"errors":null,"query":"\n    query pageConnection($before: String, $after: String, $first: Float, $last: Float, $sort: String, $filter: PageFilter) {\n  pageConnection(\n    before: $before\n    after: $after\n    first: $first\n    last: $last\n    sort: $sort\n    filter: $filter\n  ) {\n    pageInfo {\n      hasPreviousPage\n      hasNextPage\n      startCursor\n      endCursor\n    }\n    totalCount\n    edges {\n      cursor\n      node {\n        ... on Document {\n          _sys {\n            filename\n            basename\n            hasReferences\n            breadcrumbs\n            path\n            relativePath\n            extension\n          }\n          id\n        }\n        ...PageParts\n      }\n    }\n  }\n}\n    \n    fragment PageParts on Page {\n  __typename\n  title\n  body\n  enabled\n  snippet\n  icon\n}\n    "}